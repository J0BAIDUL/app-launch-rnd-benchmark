    <DataTemplate x:Key="HeavyDataTemplate00">
        <Grid Padding="10" Margin="0,0,0,5" Background="AliceBlue">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="64"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" CornerRadius="32" Background="LightGray">
                <Ellipse Fill="DodgerBlue" Width="48" Height="48"/>
            </Border>
            <StackPanel Grid.Column="1" Margin="10,0">
                <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="16"/>
                <TextBlock Text="{Binding Subtitle}" Opacity="0.6" TextWrapping="Wrap"/>
                <Grid Margin="0,4,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Progress:" VerticalAlignment="Center"/>
                    <ProgressBar Grid.Column="1" Value="0" Margin="5,0"/>
                </Grid>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Border Background="LightSteelBlue" CornerRadius="4" Padding="6,2">
                        <TextBlock Text="Tag0" FontSize="10"/>
                    </Border>
                    <Border Background="LightSteelBlue" CornerRadius="4" Padding="6,2">
                        <TextBlock Text="Tag1" FontSize="10"/>
                    </Border>
                    <Border Background="LightSteelBlue" CornerRadius="4" Padding="6,2">
                        <TextBlock Text="Tag2" FontSize="10"/>
                    </Border>
                    <Border Background="LightSteelBlue" CornerRadius="4" Padding="6,2">
                        <TextBlock Text="Tag3" FontSize="10"/>
                    </Border>
                </StackPanel>
            </StackPanel>
            <Button Grid.Column="2" Content="Action" VerticalAlignment="Center"/>
        </Grid>
    </DataTemplate>

