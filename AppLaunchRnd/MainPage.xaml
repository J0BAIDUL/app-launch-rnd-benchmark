<Page
    x:Class="MyApp.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:MyApp"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Blue"
    RequestedTheme="Dark">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Custom Title Bar -->
        <Grid x:Name="AppTitleBar" Grid.Row="0" Height="32" Background="#1AFFFFFF">
            <TextBlock Text="AppLaunchRnd Benchmark" VerticalAlignment="Center" Margin="16,0,0,0" FontSize="12" />
        </Grid>

        <!-- Main Content -->
        <Grid Grid.Row="1" Padding="40">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="16">
                <TextBlock Text="UWP XAML Parse Benchmark" FontSize="32" FontWeight="Bold" HorizontalAlignment="Center"/>
                <TextBlock x:Name="InitTimeText" FontSize="22" HorizontalAlignment="Center"/>
                <TextBlock x:Name="LaunchTimeText" FontSize="22" HorizontalAlignment="Center"/>
                <TextBlock x:Name="TotalTimeText" FontSize="26" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="Crimson"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
